{
  "name": "yangzhou-training-platform",
  "version": "1.0.0",
  "description": "扬州职业软件功能需求 Demo - 专业技术人员继续教育在线培训平台",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --targets node18-win-x64 --output dist/server.exe"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "assets": [
      "public/**/*",
      "database/**/*"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "express": "^4.21.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
